# Copy this file to `.env` and fill in your Supabase project values.
# Find them in your Supabase dashboard → Settings → API.
#
# These are CLIENT-SIDE values (the anon key is public by design and safe to ship).
# NEVER put the `service_role` secret key in here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Admin mode. Leave unset for normal users / production — premade (curated)
# dishes are then read-only and only dishes a user created can get a photo.
# Set to true in YOUR local .env to also edit premade dishes in the app.
EXPO_PUBLIC_ADMIN=false

# --- SERVER-ONLY secret (do NOT put this in .env / the app bundle) ---
# The `extract` Edge Function (OCR + recipe import) calls Claude. Its API key
# lives only on the server. Set it as a Supabase secret, never as EXPO_PUBLIC_*:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase functions deploy extract
