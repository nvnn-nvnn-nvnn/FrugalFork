# Copy this file to `.env` and fill in your Supabase project values.
# Find them in your Supabase dashboard → Settings → API.
#
# These are CLIENT-SIDE values (the anon key is public by design and safe to ship).
# NEVER put the `service_role` secret key in here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
